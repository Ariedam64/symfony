{% extends 'base.html.twig' %}

{% block titre %}
<h3> ProStages | Trié par Formations</h3>
{% endblock %}
{% block titreStage %}
Formations proposant des stages
{% endblock %}

{% block contenuSupp %}


<div class="card-deck">
  {% for formationCourante in formations %}
  <div class="card">
    <div class="card-body">
      <h5 class="card-title">{{formationCourante.getNom}}</h5>
      <p class="card-text"></p>
      <p class="card-text">{{formationCourante.getDescription}}</p>
      <p class="card-text">Stages proposé : </p>
      <ul>
        <li>
            <a href="\stages\Domotique">Domotique</a>
        </li>
        <li>
            <a href="\stages\Robotique">Robotique</a>
        </li>
        <li>
            <a href="\stages\Développement d'IA">Développement d'IA</a>
        </li>
        <li>
            <a href="\stages\Développeur Web">Développeur Web</a>
        </li>
      </ul>

    </div>
    {% endfor %}
  </div>

{% endblock %}
